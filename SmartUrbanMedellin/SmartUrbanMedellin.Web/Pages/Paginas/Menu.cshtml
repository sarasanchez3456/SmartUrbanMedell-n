@page "/"
@model SmartUrbanMedellin.Web.Pages.Paginas.MenuModel
@{
    ViewData["Title"] = "Menú Principal";
}

<h2 class="text-2xl font-bold text-slate-700 mb-6">Menú Principal</h2>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    @foreach (var item in Model.Items)
    {
        <a href="@item.Url"
           class="bg-white rounded-2xl shadow hover:shadow-lg hover:-translate-y-1 transition-all p-6 flex flex-col items-center text-center group">
            <span class="text-5xl mb-3">@item.Emoji</span>
            <h3 class="font-bold text-lg text-slate-700 group-hover:text-blue-700">@item.Titulo</h3>
            <p class="text-slate-500 text-sm mt-1">@item.Descripcion</p>
        </a>
    }
</div>