@page "/"
@model SmartUrbanMedellin.Web.Pages.Paginas.MenuModel
@{
    ViewData["Title"] = "Menú Principal";
}

<div class="page-header animate-up">
    <h2 class="page-title">Menú Principal</h2>
    <p class="text-slate-400 text-sm hidden md:block">¿Qué necesitas hoy?</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    @foreach (var (item, i) in Model.Items.Select((x,i)=>(x,i)))
    {
        <a href="@item.Url"
           class="card p-7 flex flex-col items-center text-center group animate-up no-underline"
           style="animation-delay:@(i * 0.07)s">
            <span class="text-5xl mb-4 group-hover:scale-110 transition-transform duration-200">@item.Emoji</span>
            <h3 class="font-display font-bold text-lg text-carbon mb-1.5 group-hover:text-azul transition-colors">@item.Titulo</h3>
            <p class="text-slate-400 text-sm leading-relaxed">@item.Descripcion</p>
            <span class="mt-5 text-azul text-xs font-semibold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
                Ir →
            </span>
        </a>
    }
</div>
