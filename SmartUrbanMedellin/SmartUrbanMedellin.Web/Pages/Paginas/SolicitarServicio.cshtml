@page
@model SmartUrbanMedellin.Web.Pages.Paginas.SolicitarServicioModel
@{
    ViewData["Title"] = "Solicitar Servicio";
}

<div class="flex items-center gap-3 mb-6">
    <a href="/Paginas/Solicitudes" class="text-blue-600 hover:underline text-sm">← Solicitudes</a>
    <span class="text-slate-300">/</span>
    <h2 class="text-2xl font-bold text-slate-700">📤 Solicitar Servicio</h2>
</div>

<div class="grid lg:grid-cols-5 gap-6">
    <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl shadow p-6">
            <h3 class="font-semibold text-slate-700 mb-4 pb-2 border-b">Datos de la Solicitud</h3>
            <form method="post" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-600 mb-1">Servicio *</label>
                    <select asp-for="Solicitud.IdServicio" required
                            class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-white">
                        <option value="">— Seleccionar servicio —</option>
                        @foreach (var s in Model.Servicios)
                        {
                            <option value="@s.IdServicio" @(s.IdServicio == Model.Solicitud.IdServicio ? "selected" : "")>
                                @s.Nombre — @s.Categoria
                            </option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-600 mb-1">Fecha *</label>
                    <input type="date" asp-for="Solicitud.FechaSolicitud" required
                           class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-600 mb-1">Estado</label>
                    <select asp-for="Solicitud.Estado"
                            class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-white">
                        <option>Pendiente</option>
                        <option>Activo</option>
                        <option>Cancelado</option>
                    </select>
                </div>
                <div class="pt-2 border-t">
                    <label class="block text-sm font-medium text-slate-600 mb-2">
                        📍 Ubicación del Servicio *
                        <span class="text-xs text-slate-400 font-normal">(clic en el mapa)</span>
                    </label>
                    <input type="hidden" id="inputLat" name="Lat" />
                    <input type="hidden" id="inputLng" name="Lng" />
                    <div id="coordsDisplay" class="bg-slate-100 rounded-lg px-4 py-2.5 text-xs font-mono text-slate-500">
                        Sin ubicación seleccionada
                    </div>
                </div>
                <button type="submit"
                        class="w-full bg-blue-700 text-white py-3 rounded-xl font-semibold hover:bg-blue-600 transition shadow">
                    Enviar Solicitud
                </button>
                <a href="/Paginas/Solicitudes"
                   class="block text-center text-slate-500 text-sm hover:text-slate-700 mt-1">Cancelar</a>
            </form>
        </div>
    </div>

    <div class="lg:col-span-3">
        <div class="bg-white rounded-2xl shadow overflow-hidden">
            <div class="px-6 py-4 bg-green-700 text-white font-semibold">🗺️ Indica dónde necesitas el servicio</div>
            <div class="mapa-box mapa-tall" id="mapa-solicitar"></div>
        </div>
        <p class="text-xs text-slate-400 mt-2 px-1">
            💡 Haz clic en el mapa para marcar exactamente dónde necesitas el servicio.
        </p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const m = crearMapa('mapa-solicitar', 6.2442, -75.5812, 13);
          if (!m) return;
          m.on('load', () => activarSeleccion(m, 'inputLat', 'inputLng', 'coordsDisplay'));
        });
    </script>
}