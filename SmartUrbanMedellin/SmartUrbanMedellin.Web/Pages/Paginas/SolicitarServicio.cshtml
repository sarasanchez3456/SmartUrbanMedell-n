@page
@model SmartUrbanMedellin.Web.Pages.Paginas.SolicitarServicioModel
@{
    ViewData["Title"] = "Solicitar Servicio";
}

<div class="animate-up mb-6 flex items-center gap-2 text-sm">
    <a href="/Paginas/Solicitudes" class="text-azul hover:underline">← Solicitudes</a>
    <span class="text-slate-300">/</span>
    <span class="text-slate-400">Solicitar Servicio</span>
</div>

<h2 class="page-title animate-up mb-6">📤 Solicitar Servicio</h2>

<div class="grid lg:grid-cols-5 gap-6">
    @* Form *@
    <div class="lg:col-span-2 animate-up delay-1">
        <div class="card p-6">
            <h3 class="font-display font-bold text-carbon text-base mb-5 pb-3 border-b border-slate-100">
                Datos de la Solicitud
            </h3>
            <form method="post" class="space-y-4">
                <div>
                    <label class="field-label">Servicio *</label>
                    <select asp-for="Solicitud.IdServicio" required class="input bg-white">
                        <option value="">— Seleccionar servicio —</option>
                        @foreach (var s in Model.Servicios)
                        {
                            <option value="@s.IdServicio">@s.Nombre — @s.Categoria</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="field-label">Fecha *</label>
                    <input type="date" asp-for="Solicitud.FechaSolicitud" required class="input" />
                </div>
                <div>
                    <label class="field-label">Estado</label>
                    <select asp-for="Solicitud.Estado" class="input bg-white">
                        <option>Pendiente</option>
                        <option>Activo</option>
                        <option>Cancelado</option>
                    </select>
                </div>
                <div class="pt-3 border-t border-slate-100">
                    <label class="field-label">
                        Ubicación del Servicio *
                        <span class="normal-case font-normal text-slate-400 ml-1">(clic en el mapa)</span>
                    </label>
                    <input type="hidden" id="inputLat" name="Lat" />
                    <input type="hidden" id="inputLng" name="Lng" />
                    <div id="coordsDisplay" class="coords-box">Sin ubicación seleccionada</div>
                </div>
                <button type="submit" class="btn-verde w-full mt-2">
                    Enviar Solicitud →
                </button>
                <a href="/Paginas/Solicitudes"
                   class="block text-center text-slate-400 text-sm hover:text-slate-600 mt-1 no-underline">
                    Cancelar
                </a>
            </form>
        </div>
    </div>

    @* Map *@
    <div class="lg:col-span-3 animate-up delay-2">
        <div class="card overflow-hidden">
            <div class="card-header verde">🗺️ Indica dónde necesitas el servicio</div>
            <div class="mapa-box mapa-tall" id="mapa-solicitar"></div>
        </div>
        <p class="text-xs text-slate-400 mt-2 px-1">
            💡 Haz clic en el mapa para marcar exactamente dónde necesitas el servicio.
        </p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const m = crearMapa('mapa-solicitar', 6.2442, -75.5812, 13);
          if (!m) return;
          m.on('load', () => activarSeleccion(m, 'inputLat', 'inputLng', 'coordsDisplay'));
        });
    </script>
}
