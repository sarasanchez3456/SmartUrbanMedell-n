@page
@model SmartUrbanMedellin.Web.Pages.Paginas.SolicitudesModel
@{
    ViewData["Title"] = "Solicitudes";
}

<div class="page-header animate-up">
    <div>
        <h2 class="page-title">📋 Solicitudes</h2>
        <p class="text-slate-400 text-sm mt-0.5">Historial y estado de tus solicitudes de servicio</p>
    </div>
    <a href="/Paginas/SolicitarServicio" class="btn-verde inline-flex items-center gap-2 no-underline">
        + Nueva Solicitud
    </a>
</div>

@* Leyenda + mapa *@
<div class="card overflow-hidden mb-6 animate-up delay-1">
    <div class="card-header azul flex gap-6 items-center flex-wrap">
        <span>🗺️ Solicitudes Activas en el Mapa</span>
        <div class="ml-auto flex gap-4 text-xs font-medium">
            <span class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-400 inline-block"></span>Pendiente
            </span>
            <span class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-verde inline-block"></span>Activo
            </span>
            <span class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400 inline-block"></span>Cancelado
            </span>
        </div>
    </div>
    <div class="mapa-box" id="mapa-solicitudes"></div>
</div>

@* Table *@
<div class="card overflow-hidden animate-up delay-2">
    <div class="card-header grafito">Listado de Solicitudes</div>
    <div class="overflow-x-auto">
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Servicio</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Solicitudes)
                {
                    <tr>
                        <td class="font-mono text-slate-400 text-xs">#@s.IdSolicitud</td>
                        <td class="font-semibold text-carbon">Servicio @s.IdServicio</td>
                        <td class="text-slate-500">@s.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                        <td>
                            @{
                                var badgeClass = s.Estado switch {
                                    "Activo"    => "badge-verde",
                                    "Pendiente" => "badge-amarillo",
                                    _           => "badge-rojo"
                                };
                            }
                            <span class="badge @badgeClass">@s.Estado</span>
                        </td>
                        <td class="text-center">
                            <a href="/Paginas/CalificarServicio?id=@s.IdSolicitud"
                               class="badge badge-amarillo hover:opacity-80 transition no-underline">
                                ⭐ Calificar
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Solicitudes.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-slate-300 py-12 text-sm">
                            <span class="text-3xl block mb-2">📋</span>
                            No hay solicitudes aún
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const solGeo = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SolicitudesGeo));
        document.addEventListener('DOMContentLoaded', () => {
          const m = crearMapa('mapa-solicitudes', 6.2442, -75.5812, 12);
          if (!m) return;
          m.on('load', () => {
            const colores = { 'Pendiente':'#F5C400', 'Activo':'#00C47A', 'Cancelado':'#ef4444' };
            solGeo.forEach(s => {
              if (s.lat && s.lng)
                agregarPin(m, s.lng, s.lat, `#${s.id} — ${s.estado}`, colores[s.estado] || '#1B3FE4');
            });
          });
        });
    </script>
}
