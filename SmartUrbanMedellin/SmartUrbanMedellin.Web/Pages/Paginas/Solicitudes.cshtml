@page
@model SmartUrbanMedellin.Web.Pages.Paginas.SolicitudesModel
@{
    ViewData["Title"] = "Solicitudes";
}

<div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-slate-700">📋 Solicitudes</h2>
    <a href="/Paginas/SolicitarServicio"
       class="bg-blue-700 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-blue-600 transition shadow">
        + Nueva Solicitud
    </a>
</div>

<div class="bg-white rounded-2xl shadow overflow-hidden mb-6">
    <div class="px-6 py-4 bg-blue-700 text-white font-semibold flex gap-4 items-center flex-wrap">
        <span>🗺️ Solicitudes Activas en el Mapa</span>
        <div class="ml-auto flex gap-3 text-xs">
            <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span>Pendiente</span>
            <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>Activo</span>
            <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>Cancelado</span>
        </div>
    </div>
    <div class="mapa-box" id="mapa-solicitudes"></div>
</div>

<div class="bg-white rounded-2xl shadow overflow-hidden">
    <div class="px-6 py-4 bg-slate-700 text-white font-semibold">Listado de Solicitudes</div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-slate-100 text-slate-600 uppercase text-xs">
                <tr>
                    <th class="px-4 py-3 text-left">#</th>
                    <th class="px-4 py-3 text-left">Servicio</th>
                    <th class="px-4 py-3 text-left">Fecha</th>
                    <th class="px-4 py-3 text-left">Estado</th>
                    <th class="px-4 py-3 text-center">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var s in Model.Solicitudes)
                {
                    <tr class="hover:bg-slate-50 transition">
                        <td class="px-4 py-3 font-mono text-slate-400">#@s.IdSolicitud</td>
                        <td class="px-4 py-3 font-medium">Servicio @s.IdServicio</td>
                        <td class="px-4 py-3 text-slate-500">@s.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                        <td class="px-4 py-3">
                            @{
                                var badge = s.Estado switch
                                {
                                    "Activo" => "bg-green-100 text-green-700",
                                    "Pendiente" => "bg-yellow-100 text-yellow-700",
                                    _ => "bg-red-100 text-red-700"
                                };
                            }
                            <span class="px-3 py-1 rounded-full text-xs font-semibold @badge">@s.Estado</span>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <a href="/Paginas/CalificarServicio?id=@s.IdSolicitud"
                               class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-lg text-xs font-semibold hover:bg-yellow-200 transition">
                                ⭐ Calificar
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Solicitudes.Any())
                {
                    <tr><td colspan="5" class="text-center text-slate-400 py-10">No hay solicitudes aún</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const solGeo = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SolicitudesGeo));
        document.addEventListener('DOMContentLoaded', () => {
          const m = crearMapa('mapa-solicitudes', 6.2442, -75.5812, 12);
          if (!m) return;
          m.on('load', () => {
            const colores = { 'Pendiente':'#f59e0b', 'Activo':'#22c55e', 'Cancelado':'#ef4444' };
            solGeo.forEach(s => {
              if (s.lat && s.lng)
                agregarPin(m, s.lng, s.lat, `#${s.id} — ${s.estado}`, colores[s.estado] || '#1d4ed8');
            });
          });
        });
    </script>
}