@page
@model SmartUrbanMedellin.Web.Pages.Paginas.RegistrarProveedorModel
@{
    ViewData["Title"] = "Registrar Proveedor";
}

<div class="animate-up mb-6 flex items-center gap-2 text-sm">
    <a href="/Paginas/Proveedores" class="text-azul hover:underline">← Proveedores</a>
    <span class="text-slate-300">/</span>
    <span class="text-slate-400">Registrar Proveedor</span>
</div>

<h2 class="page-title animate-up mb-6">Registrar Proveedor</h2>

<div class="grid lg:grid-cols-5 gap-6">
    @* Form *@
    <div class="lg:col-span-2 animate-up delay-1">
        <div class="card p-6">
            <h3 class="font-display font-bold text-carbon text-base mb-5 pb-3 border-b border-slate-100">
                Datos del Proveedor
            </h3>
            <form method="post" class="space-y-4">
                <div>
                    <label class="field-label">Razón Social *</label>
                    <input type="text" asp-for="Proveedor.RazonSocial" required
                           class="input" placeholder="Ej: Eléctricos del Norte" />
                </div>
                <div>
                    <label class="field-label">Contacto *</label>
                    <input type="text" asp-for="Proveedor.Contacto" required
                           class="input" placeholder="Nombre del responsable" />
                </div>
                <div>
                    <label class="field-label">Teléfono *</label>
                    <input type="tel" asp-for="Proveedor.Telefono" required
                           class="input" placeholder="3001234567" />
                </div>
                <div>
                    <label class="field-label">Correo *</label>
                    <input type="email" asp-for="Proveedor.Correo" required
                           class="input" placeholder="correo@empresa.com" />
                </div>
                <div class="pt-3 border-t border-slate-100">
                    <label class="field-label">
                        Ubicación *
                        <span class="normal-case font-normal text-slate-400 ml-1">(clic en el mapa)</span>
                    </label>
                    <input type="hidden" id="inputLat" name="Lat" />
                    <input type="hidden" id="inputLng" name="Lng" />
                    <div id="coordsDisplay" class="coords-box">Sin ubicación seleccionada</div>
                </div>
                <button type="submit" class="btn-primary w-full mt-2">
                    Guardar Proveedor →
                </button>
                <a href="/Paginas/Proveedores"
                   class="block text-center text-slate-400 text-sm hover:text-slate-600 mt-1 no-underline">
                    Cancelar
                </a>
            </form>
        </div>
    </div>

    @* Map *@
    <div class="lg:col-span-3 animate-up delay-2">
        <div class="card overflow-hidden">
            <div class="card-header verde">🗺️ Seleccionar Ubicación en Medellín</div>
            <div class="mapa-box mapa-tall" id="mapa-registro"></div>
        </div>
        <p class="text-xs text-slate-400 mt-2 px-1">
            💡 Haz clic en el mapa para marcar la dirección exacta del proveedor.
        </p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const m = crearMapa('mapa-registro', 6.2442, -75.5812, 13);
          if (!m) return;
          m.on('load', () => activarSeleccion(m, 'inputLat', 'inputLng', 'coordsDisplay'));
        });
    </script>
}
