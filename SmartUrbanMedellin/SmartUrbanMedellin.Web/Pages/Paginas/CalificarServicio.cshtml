@page
@model SmartUrbanMedellin.Web.Pages.Paginas.CalificarServicioModel
@{
    ViewData["Title"] = "Calificar Servicio";
}

<div class="animate-up mb-6 flex items-center gap-2 text-sm">
    <a href="/Paginas/Solicitudes" class="text-azul hover:underline">← Solicitudes</a>
    <span class="text-slate-300">/</span>
    <span class="text-slate-400">Calificar Servicio</span>
</div>

<div class="max-w-md mx-auto animate-up delay-1">
    <div class="card p-8">
        @* Header *@
        <div class="text-center mb-8">
            <div class="w-16 h-16 rounded-2xl bg-oro/10 flex items-center justify-center text-4xl mx-auto mb-3">⭐</div>
            <h2 class="font-display font-black text-2xl text-carbon mb-1">Calificar Servicio</h2>
            <p class="text-slate-400 text-sm">Tu opinión ayuda a otros ciudadanos a elegir mejor</p>
        </div>

        <form method="post" class="space-y-6">
            <input type="hidden" asp-for="Calificacion.IdSolicitud" />

            @* Star rating *@
            <div>
                <label class="field-label text-center block mb-4">¿Cómo calificarías el servicio?</label>
                <div class="star-group">
                    @for (int i = 5; i >= 1; i--)
                    {
                        <label>
                            <input type="radio" asp-for="Calificacion.Puntuacion" value="@i" />
                            ⭐
                        </label>
                    }
                </div>
                <div class="flex justify-between text-xs text-slate-300 mt-2 px-1">
                    <span>Muy malo</span>
                    <span>Excelente</span>
                </div>
            </div>

            @* Comment *@
            <div>
                <label class="field-label">Comentario</label>
                <textarea asp-for="Calificacion.Comentario" rows="4"
                          placeholder="Describe tu experiencia con este servicio..."
                          class="input resize-none"></textarea>
            </div>

            <button type="submit" class="btn-oro w-full text-base py-3.5 font-display font-black">
                ⭐ Enviar Calificación
            </button>
            <a href="/Paginas/Solicitudes"
               class="block text-center text-slate-400 text-sm hover:text-slate-600 no-underline">
                Cancelar
            </a>
        </form>
    </div>
</div>
