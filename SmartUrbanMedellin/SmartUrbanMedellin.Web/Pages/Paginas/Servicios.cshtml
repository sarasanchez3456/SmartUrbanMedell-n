@page
@model SmartUrbanMedellin.Web.Pages.Paginas.ServiciosModel
@{
    ViewData["Title"] = "Servicios";
}

<div class="page-header animate-up">
    <div>
        <h2 class="page-title">🛠️ Servicios Disponibles</h2>
        <p class="text-slate-400 text-sm mt-0.5">Encuentra el servicio que necesitas en tu zona</p>
    </div>
</div>

@* Búsqueda *@
<div class="card p-4 mb-6 animate-up delay-1">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">Buscar por zona</p>
    <div class="flex gap-3 flex-wrap">
        <input id="zonaInput" type="text"
               placeholder="Ej: El Poblado, Laureles, Bello, Itagüí..."
               class="input flex-1 min-w-48" />
        <button onclick="buscarZona()" class="btn-primary shrink-0">
            Ver en Mapa →
        </button>
    </div>
</div>

@* Map *@
<div class="card overflow-hidden mb-8 animate-up delay-2">
    <div class="card-header azul">🗺️ Servicios por Zona — Medellín y Área Metropolitana</div>
    <div class="mapa-box" id="mapa-servicios"></div>
</div>

@* Cards *@
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    @foreach (var (s, i) in Model.Servicios.Select((x,i)=>(x,i)))
    {
        <div class="card overflow-hidden animate-up" style="animation-delay:@(i * 0.06)s">
            <div class="@s.ColorBg px-5 py-4 flex items-center gap-3">
                <span class="text-3xl">@s.Emoji</span>
                <div>
                    <h3 class="font-display font-bold text-white text-base leading-tight">@s.Nombre</h3>
                    <span class="text-xs text-white/70">@s.Categoria</span>
                </div>
            </div>
            <div class="p-4">
                <p class="text-slate-500 text-sm mb-4 leading-relaxed">@s.Descripcion</p>
                <a href="/Paginas/SolicitarServicio?idServicio=@s.IdServicio"
                   class="btn-primary block text-center no-underline text-sm">
                    Solicitar →
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        let mapaS;
        document.addEventListener('DOMContentLoaded', () => {
          mapaS = crearMapa('mapa-servicios', 6.2442, -75.5812, 11);
          if (!mapaS) return;
          mapaS.on('load', () => {
            agregarPin(mapaS, -75.5681, 6.2090, '⚡ Electricidad — El Poblado', '#1B3FE4');
            agregarPin(mapaS, -75.5950, 6.2442, '🔧 Plomería — Laureles',       '#00C47A');
            agregarPin(mapaS, -75.5500, 6.2650, '🌿 Jardinería — Poblado',      '#16a34a');
            agregarPin(mapaS, -75.6050, 6.2220, '🪚 Carpintería — Belén',       '#F5C400');
            agregarPin(mapaS, -75.5812, 6.3100, '🎨 Pintura — Bello',           '#ef4444');
            agregarPin(mapaS, -75.5900, 6.1750, '🧹 Limpieza — Envigado',       '#7c3aed');
          });
        });

        function buscarZona() {
          const texto = document.getElementById('zonaInput').value.trim();
          if (!mapaS || !texto) return;
          const url = `https://api.maptiler.com/geocoding/${encodeURIComponent(texto + ', Medellín, Colombia')}.json?key=${MAPTILER_KEY}&limit=1`;
          fetch(url).then(r => r.json()).then(data => {
            if (data.features?.length > 0) {
              const [lng, lat] = data.features[0].center;
              mapaS.flyTo({ center: [lng, lat], zoom: 14, duration: 1000 });
              agregarPin(mapaS, lng, lat, '🔍 ' + texto, '#1B3FE4');
            }
          });
        }
    </script>
}
