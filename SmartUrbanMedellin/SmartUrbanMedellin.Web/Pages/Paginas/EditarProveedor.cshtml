@page
@model SmartUrbanMedellin.Web.Pages.Paginas.EditarProveedorModel
@{
    ViewData["Title"] = "Editar Proveedor";
}

<div class="animate-up mb-6 flex items-center gap-2 text-sm">
    <a href="/Paginas/Proveedores" class="text-azul hover:underline">← Proveedores</a>
    <span class="text-slate-300">/</span>
    <span class="text-slate-400">Editar Proveedor</span>
</div>

<h2 class="page-title animate-up mb-6">Editar Proveedor</h2>

<div class="grid lg:grid-cols-5 gap-6">
    @* Form *@
    <div class="lg:col-span-2 animate-up delay-1">
        <div class="card p-6">
            <h3 class="font-display font-bold text-carbon text-base mb-5 pb-3 border-b border-slate-100">
                Actualizar Datos
            </h3>
            <form method="post" class="space-y-4">
                <input type="hidden" asp-for="Proveedor.IdProveedor" />
                <div>
                    <label class="field-label">Razón Social</label>
                    <input type="text" asp-for="Proveedor.RazonSocial" class="input" />
                </div>
                <div>
                    <label class="field-label">Contacto</label>
                    <input type="text" asp-for="Proveedor.Contacto" class="input" />
                </div>
                <div>
                    <label class="field-label">Teléfono</label>
                    <input type="tel" asp-for="Proveedor.Telefono" class="input" />
                </div>
                <div>
                    <label class="field-label">Correo</label>
                    <input type="email" asp-for="Proveedor.Correo" class="input" />
                </div>
                <div class="pt-3 border-t border-slate-100">
                    <label class="field-label">
                        Actualizar Ubicación
                        <span class="normal-case font-normal text-slate-400 ml-1">(clic en el mapa)</span>
                    </label>
                    <input type="hidden" id="inputLat" name="Lat" value="@Model.Lat" />
                    <input type="hidden" id="inputLng" name="Lng" value="@Model.Lng" />
                    <div id="coordsDisplay" class="coords-box">
                        Lat: @Model.Lat · Lng: @Model.Lng
                    </div>
                </div>
                <button type="submit" class="btn-oro w-full mt-2">
                    Actualizar Proveedor →
                </button>
                <a href="/Paginas/Proveedores"
                   class="block text-center text-slate-400 text-sm hover:text-slate-600 mt-1 no-underline">
                    Cancelar
                </a>
            </form>
        </div>
    </div>

    @* Map *@
    <div class="lg:col-span-3 animate-up delay-2">
        <div class="card overflow-hidden">
            <div class="card-header oro">🗺️ Ubicación Actual — Clic para mover</div>
            <div class="mapa-box mapa-tall" id="mapa-editar"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const lat = parseFloat('@Model.Lat') || 6.2442;
          const lng = parseFloat('@Model.Lng') || -75.5812;
          const m = crearMapa('mapa-editar', lat, lng, 15);
          if (!m) return;
          m.on('load', () => {
            agregarPin(m, lng, lat, '📍 Ubicación actual', '#F5C400');
            activarSeleccion(m, 'inputLat', 'inputLng', 'coordsDisplay');
          });
        });
    </script>
}
