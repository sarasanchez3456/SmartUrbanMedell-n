@page
@model SmartUrbanMedellin.Web.Pages.Paginas.DefaultModel
@{
    ViewData["Title"] = "Inicio";
}

@* Hero *@
<section class="relative overflow-hidden rounded-3xl mb-8 animate-up" style="background:linear-gradient(135deg,#0F1523 0%,#1E2840 60%,#1230B0 100%);min-height:280px;">
    @* Decorative circles *@
    <div style="position:absolute;top:-60px;right:-60px;width:300px;height:300px;border-radius:50%;background:rgba(0,196,122,.08);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-80px;right:120px;width:200px;height:200px;border-radius:50%;background:rgba(27,63,228,.15);pointer-events:none;"></div>

    <div class="relative px-8 py-10 md:py-14 max-w-2xl">
        <span class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest text-verde mb-4">
            <span class="w-2 h-2 rounded-full bg-verde inline-block animate-pulse"></span>
            Servicios activos en Medellín
        </span>
        <h1 class="font-display text-3xl md:text-4xl font-black text-white leading-tight mb-3">
            Tu ciudad, tus<br><span class="text-verde">servicios.</span>
        </h1>
        <p class="text-white/60 text-base max-w-lg mb-7">
            Conectamos ciudadanos con plomeros, electricistas, carpinteros y más — rápido, seguro y cerca de ti.
        </p>
        <div class="flex gap-3 flex-wrap">
            <a href="/Paginas/Servicios" class="btn-verde inline-flex items-center gap-2">
                <span>Ver Servicios</span> <span>→</span>
            </a>
            <a href="/Paginas/RegistrarProveedor"
               style="background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2);"
               class="inline-flex items-center gap-2 font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-white/20 transition">
                Ofrecer un servicio
            </a>
        </div>
    </div>
</section>

@* Stats *@
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    @foreach (var (stat, i) in Model.Stats.Select((s,i)=>(s,i)))
    {
        <a href="@stat.Url"
           class="card p-5 flex flex-col items-center text-center cursor-pointer animate-up delay-@(i+1) no-underline">
            <span class="text-3xl mb-2">@stat.Emoji</span>
            <span class="font-display text-2xl font-black text-azul">@stat.Valor</span>
            <span class="text-slate-400 text-xs mt-1 font-medium">@stat.Etiqueta</span>
        </a>
    }
</div>

@* Map *@
<div class="card overflow-hidden animate-up delay-4">
    <div class="card-header azul flex items-center gap-2">
        🗺️ <span>Servicios disponibles en Medellín</span>
    </div>
    <div class="mapa-box" id="mapa-inicio"></div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const m = crearMapa('mapa-inicio', 6.2442, -75.5812, 12);
          if (!m) return;
          m.on('load', () => {
            agregarPin(m, -75.5681, 6.2530, '⚡ El Poblado — Electricidad', '#1B3FE4');
            agregarPin(m, -75.5900, 6.2700, '🔧 Laureles — Plomería',       '#00C47A');
            agregarPin(m, -75.5750, 6.2100, '🏠 Envigado — Limpieza',       '#7c3aed');
            agregarPin(m, -75.5812, 6.2442, '🪚 Centro — Carpintería',      '#F5C400');
            agregarPin(m, -75.6050, 6.2600, '🎨 Belén — Pintura',           '#ef4444');
          });
        });
    </script>
}
