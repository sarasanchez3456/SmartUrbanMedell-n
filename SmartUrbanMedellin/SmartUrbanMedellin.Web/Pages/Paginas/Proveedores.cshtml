@page
@model SmartUrbanMedellin.Web.Pages.Paginas.ProveedoresModel
@{
    ViewData["Title"] = "Proveedores";
}

<div class="page-header animate-up">
    <div>
        <h2 class="page-title">🏪 Proveedores</h2>
        <p class="text-slate-400 text-sm mt-0.5">Gestiona los proveedores de servicio registrados</p>
    </div>
    <a href="/Paginas/RegistrarProveedor" class="btn-verde inline-flex items-center gap-2 no-underline">
        + Nuevo Proveedor
    </a>
</div>

@* Search bar *@
<div class="card p-4 mb-6 flex gap-3 items-center animate-up delay-1">
    <span class="text-slate-400 text-sm font-medium shrink-0">🔍</span>
    <input id="busquedaBarrio" type="text"
           placeholder="Buscar por barrio: El Poblado, Laureles, Envigado..."
           class="input flex-1"
           oninput="buscarEnMapa(this.value)" />
    <button onclick="buscarEnMapa(document.getElementById('busquedaBarrio').value)"
            class="btn-verde shrink-0">
        Buscar
    </button>
</div>

<div class="grid lg:grid-cols-2 gap-6">
    @* Table *@
    <div class="card overflow-hidden animate-up delay-2">
        <div class="card-header azul">Lista de Proveedores</div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Razón Social</th>
                        <th>Contacto</th>
                        <th>Teléfono</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Proveedores)
                    {
                        <tr>
                            <td class="font-semibold text-carbon">@p.RazonSocial</td>
                            <td class="text-slate-500">@p.Contacto</td>
                            <td class="text-slate-500 font-mono text-xs">@p.Telefono</td>
                            <td class="text-center">
                                <a href="/Paginas/EditarProveedor?id=@p.IdProveedor"
                                   class="badge badge-azul mr-1 hover:opacity-80 transition no-underline cursor-pointer">✏️ Editar</a>
                                <button onclick="confirmarEliminar('@p.RazonSocial')"
                                        class="badge badge-rojo hover:opacity-80 transition border-0 cursor-pointer">
                                    🗑️
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Proveedores.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-slate-300 py-12 text-sm">
                                <span class="text-3xl block mb-2">🏪</span>
                                No hay proveedores registrados aún
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Map *@
    <div class="card overflow-hidden animate-up delay-3">
        <div class="card-header verde">📍 Ubicación de Proveedores</div>
        <div class="mapa-box" id="mapa-proveedores"></div>
    </div>
</div>

@section Scripts {
    <script>
        const provGeo = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProveedoresGeo));
        let mapaP;

        document.addEventListener('DOMContentLoaded', () => {
          mapaP = crearMapa('mapa-proveedores', 6.2442, -75.5812, 12);
          if (!mapaP) return;
          mapaP.on('load', () => {
            provGeo.forEach(p => {
              if (p.lat && p.lng) agregarPin(mapaP, p.lng, p.lat, p.razonSocial, '#00C47A');
            });
          });
        });

        function buscarEnMapa(texto) {
          if (!mapaP || !texto.trim()) return;
          const url = `https://api.maptiler.com/geocoding/${encodeURIComponent(texto + ', Medellín, Colombia')}.json?key=${MAPTILER_KEY}&limit=1`;
          fetch(url).then(r => r.json()).then(data => {
            if (data.features?.length > 0) {
              const [lng, lat] = data.features[0].center;
              mapaP.flyTo({ center: [lng, lat], zoom: 14, duration: 1200 });
              agregarPin(mapaP, lng, lat, '🔍 ' + texto, '#1B3FE4');
            }
          });
        }

        function confirmarEliminar(nombre) {
          if (confirm(`¿Eliminar a ${nombre}?`)) { /* TODO: llamar endpoint */ }
        }
    </script>
}
